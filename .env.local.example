# Microsoft Entra (Azure AD) app registration — multi-tenant SaaS
# Register at portal.azure.com → App registrations → New registration
# Supported account types: "Any Azure AD directory + personal Microsoft accounts"
NEXT_PUBLIC_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_AUTHORITY=https://login.microsoftonline.com/common
NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000

# Google Gemini — server-side only, your cost, all clients share this key
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Chrome path for Puppeteer in production (leave blank for local dev)
PUPPETEER_EXECUTABLE_PATH=
